# TikTok Signature Server Configuration
# Copy this file to .env and fill in your values

# Server port (default: 8080)
PORT=8080

# Proxy Configuration (optional)
# Set PROXY_ENABLED=true to use a proxy
PROXY_ENABLED=false
PROXY_HOST=proxy.example.com:8080
PROXY_USER=your_username
PROXY_PASS=your_password

# Chrome executable path (optional, auto-detected by default)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Auto-refresh tuning (optional)
# Restart browser after this many signatures (default: 500)
#MAX_GENERATIONS_BEFORE_REFRESH=500
# Restart browser after this many ms of session age (default: 1800000 = 30 min)
#MAX_SESSION_AGE_MS=1800000
